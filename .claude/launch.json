{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "project-gantt",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),f=p.join('C:/Users/Dan/repos/project-gantt',q.url==='/'?'index.html':q.url),e=p.extname(f),m={'.html':'text/html','.svg':'image/svg+xml','.js':'text/javascript','.css':'text/css'};fs.readFile(f,(err,d)=>{if(err){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':m[e]||'application/octet-stream'});r.end(d);}});}).listen(3010,()=>console.log('Server on 3010'))"],
      "port": 3010
    }
  ]
}
